#!/bin/sh
# pg — start/stop/status PostgreSQL (data in .devcontainer/.pgdata/)
set -e

PGDATA="${WORKSPACE_FOLDER:-.}/.devcontainer/.pgdata"

case "${1:-start}" in
    start)
        pg_ctl -D "$PGDATA" status >/dev/null 2>&1 && exit 0
        # Remove stale PID file from previous container run
        if [ -f "$PGDATA/postmaster.pid" ]; then
            PID=$(head -1 "$PGDATA/postmaster.pid")
            if ! kill -0 "$PID" 2>/dev/null; then
                rm -f "$PGDATA/postmaster.pid"
            fi
        fi
        if [ ! -d "$PGDATA" ]; then
            initdb -D "$PGDATA" --auth=trust --no-locale -E UTF8
            echo "host all all 0.0.0.0/0 trust" >> "$PGDATA/pg_hba.conf"
            cat >> "$PGDATA/postgresql.conf" <<PGCONF
listen_addresses = '*'
unix_socket_directories = '/tmp'
PGCONF
            pg_ctl -D "$PGDATA" -l "$PGDATA/server.log" start
            createdb -h /tmp "$(whoami)"
            psql -h /tmp -c "CREATE ROLE postgres WITH LOGIN CREATEDB SUPERUSER;" 2>/dev/null || true
        else
            # Ensure socket directory exists (may differ from /tmp in older configs)
            grep '^unix_socket_directories' "$PGDATA/postgresql.conf" | sed "s/.*= *'//;s/'.*//" | tr ',' '\n' | while read -r d; do
                d=$(echo "$d" | xargs)
                [ -n "$d" ] && mkdir -p "$d"
            done
            pg_ctl -D "$PGDATA" -l "$PGDATA/server.log" start
        fi
        ;;
    stop)
        pg_ctl -D "$PGDATA" stop
        ;;
    status)
        pg_ctl -D "$PGDATA" status
        ;;
    log)
        tail -f "$PGDATA/server.log"
        ;;
    *)
        echo "Usage: pg [start|stop|status|log]"
        exit 1
        ;;
esac
