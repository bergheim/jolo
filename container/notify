#!/bin/sh
# notify — Send push notification when an AI agent finishes.
# Called by agent session-end hooks. Receives JSON context on stdin.
#
# Usage:
#   notify              — always send notification (original behavior)
#   notify stamp        — record current time to $HOME/.notify-prompt-start
#   notify --if-slow S  — notify only if >S seconds since stamp
#   notify --path /foo  — set NOTIFY_PATH for this invocation
#
# Environment:
#   NTFY_SERVER  — ntfy server URL (default: https://ntfy.sh)
#   NTFY_TOPIC   — notification topic (default: jolo)
#   PROJECT      — project name (default: unknown)
#   AGENT        — agent name (default: unknown)
#   NOTIFY_APP   — set to 1 to enable "Open app" button (web projects)
#   NOTIFY_PATH  — app-relative path for dev URL (e.g. /article/123)

set -e

format_elapsed() {
    _secs=$1
    if [ "$_secs" -ge 3600 ]; then
        printf '%dh %dm' $((_secs / 3600)) $((_secs % 3600 / 60))
    elif [ "$_secs" -ge 60 ]; then
        printf '%dm %ds' $((_secs / 60)) $((_secs % 60))
    else
        printf '%ds' "$_secs"
    fi
}

terminal_attention_sequence() {
    # CSI 5t asks supporting terminals to raise the window; BEL marks urgent.
    printf '\033[5t\a'
}

raise_terminal() {
    if [ -w /dev/tty ]; then
        terminal_attention_sequence >/dev/tty 2>/dev/null || true
    else
        terminal_attention_sequence 2>/dev/null || true
    fi
}

# Allow sourcing just the functions for testing
if [ "${1:-}" = "--source-only" ]; then
    return 0 2>/dev/null || exit 0
fi

STAMP_FILE="$HOME/.notify-prompt-start"

# --- stamp mode: record current time and exit ---
if [ "${1:-}" = "stamp" ]; then
    date +%s > "$STAMP_FILE"
    exit 0
fi

# --- set-path: persist path for next notification ---
if [ "${1:-}" = "set-path" ]; then
    echo "${2:-}" > "$HOME/.notify-path"
    exit 0
fi

# --- --path: set NOTIFY_PATH from arg ---
if [ "${1:-}" = "--path" ]; then
    NOTIFY_PATH="${2:-}"
    shift 2
fi

# --- --if-slow mode: check elapsed time, notify only if slow ---
if [ "${1:-}" = "--if-slow" ]; then
    THRESHOLD="${2:?Usage: notify --if-slow SECONDS}"

    # Silently exit if no stamp file
    [ -f "$STAMP_FILE" ] || exit 0

    START=$(cat "$STAMP_FILE")
    rm -f "$STAMP_FILE"
    NOW=$(date +%s)
    ELAPSED=$((NOW - START))

    # Exit silently if under threshold
    [ "$ELAPSED" -gt "$THRESHOLD" ] || exit 0

    # Fall through to send notification with elapsed info
    ELAPSED_INFO=" ($(format_elapsed "$ELAPSED"))"
fi

# If no --if-slow, still include elapsed time when available
if [ -z "${ELAPSED_INFO:-}" ] && [ -f "$STAMP_FILE" ]; then
    START=$(cat "$STAMP_FILE")
    rm -f "$STAMP_FILE"
    NOW=$(date +%s)
    ELAPSED=$((NOW - START))
    ELAPSED_INFO=" ($(format_elapsed "$ELAPSED"))"
fi

SERVER="${NTFY_SERVER:-https://ntfy.sh}"
TOPIC="${NTFY_TOPIC:-jolo}"
PROJECT="${PROJECT:-unknown}"
AGENT="${AGENT:-unknown}"

# Drain stdin (agents pipe JSON context) — skip if interactive terminal
if [ ! -t 0 ]; then
    cat >/dev/null 2>&1 || true
fi

TITLE="${PROJECT} - ${AGENT} done${ELAPSED_INFO:-}"
BODY=""

LAST_COMMIT=$(git -C "${WORKSPACE:-$PWD}" log -1 --pretty=%s 2>/dev/null || true)
[ -n "$LAST_COMMIT" ] && BODY="${LAST_COMMIT}"

COMMIT_URL=""
REPO_URL=$(git -C "${WORKSPACE:-$PWD}" remote get-url origin 2>/dev/null || true)
SHA=$(git -C "${WORKSPACE:-$PWD}" rev-parse HEAD 2>/dev/null || true)
if [ -n "$REPO_URL" ] && [ -n "$SHA" ]; then
    REPO_URL=${REPO_URL%.git}
    case "$REPO_URL" in
        git@github.com:*)
            REPO_URL="https://github.com/${REPO_URL#git@github.com:}"
            ;;
    esac
    case "$REPO_URL" in
        https://github.com/*)
            COMMIT_URL="${REPO_URL}/commit/${SHA}"
            ;;
    esac
fi
CLICK_HEADER=""
ACTIONS=""

# Read persisted path if not already set
if [ -z "${NOTIFY_PATH:-}" ] && [ -f "$HOME/.notify-path" ]; then
    NOTIFY_PATH=$(cat "$HOME/.notify-path")
fi

# Button 1: dev app URL (only for web projects with NOTIFY_APP=1)
if [ -n "${NOTIFY_APP:-}" ] && [ -n "${DEV_HOST:-}" ] && [ -n "${PORT:-}" ]; then
    DEV_URL="http://${DEV_HOST}:${PORT}${NOTIFY_PATH:-}"
    CLICK_HEADER="Click: ${DEV_URL}"
    ACTIONS="view, Open app, ${DEV_URL}"
fi

# Button 2: PR if on a branch, otherwise commit
PR_URL=$(gh pr view --json url -q .url 2>/dev/null || true)
if [ -n "$PR_URL" ]; then
    [ -z "$CLICK_HEADER" ] && CLICK_HEADER="Click: ${PR_URL}"
    ACTIONS="${ACTIONS:+${ACTIONS}; }view, View PR, ${PR_URL}"
elif [ -n "$COMMIT_URL" ]; then
    [ -z "$CLICK_HEADER" ] && CLICK_HEADER="Click: ${COMMIT_URL}"
    ACTIONS="${ACTIONS:+${ACTIONS}; }view, View commit, ${COMMIT_URL}"
fi

ACTIONS_HEADER=""
[ -n "$ACTIONS" ] && ACTIONS_HEADER="Actions: ${ACTIONS}"

# Fire and forget — don't let notification failure affect the agent
curl -sf --max-time 5 \
    -H "Title: ${TITLE}" \
    -H "Priority: default" \
    -H "Tags: robot,checkmark" \
    ${CLICK_HEADER:+-H "$CLICK_HEADER"} \
    ${ACTIONS_HEADER:+-H "$ACTIONS_HEADER"} \
    -d "${BODY}" \
    "${SERVER}/${TOPIC}" \
    >/dev/null 2>&1 || true

# Terminal attention — raise supporting host terminals and set urgent flag.
raise_terminal

# --- Research TTS: generate audio and send as ntfy attachment ---
KOKORO_URL="${KOKORO_URL:-}"
if [ "$PROJECT" = "research" ] && [ -n "$KOKORO_URL" ]; then
    ORG_FILE=$(ls -t /workspaces/research/*.org 2>/dev/null | head -1)
    if [ -n "$ORG_FILE" ]; then
        TEXT=$(sed \
            -e '/^#+/d' \
            -e 's/^\*\+ //' \
            -e 's/\[\[[^]]*\]\[\([^]]*\)\]\]/\1/g' \
            -e 's/\[\[[^]]*\]\]//g' \
            -e 's/^- //' \
            "$ORG_FILE")
        TOPIC_SLUG=$(basename "$ORG_FILE" .org)
        TMP_MP3="/tmp/research-audio-$$.mp3"

        JSON_TEXT=$(printf '%s' "$TEXT" | jq -Rs .)
        if curl -sf --max-time 120 \
            -H "Content-Type: application/json" \
            -d "{\"model\":\"kokoro\",\"input\":${JSON_TEXT},\"voice\":\"af_heart\",\"response_format\":\"mp3\"}" \
            "${KOKORO_URL}/v1/audio/speech" \
            -o "$TMP_MP3" 2>/dev/null; then

            curl -sf --max-time 15 \
                -H "Title: ${PROJECT} — ${AGENT} research" \
                -H "Filename: ${TOPIC_SLUG}.mp3" \
                -T "$TMP_MP3" \
                "${SERVER}/${TOPIC}" \
                >/dev/null 2>&1 || true
        fi
        rm -f "$TMP_MP3"
    fi
fi
