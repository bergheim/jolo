#!/bin/sh
# Copy a file/dir to the host stash and emit a tailnet URL pointing at
# it. See AGENTS.md "Sharing files to the local laptop" for host setup.

set -eu

target=${1:-.}

if [ ! -e "$target" ]; then
    echo "share: not found: $target" >&2
    exit 1
fi

abs=$(realpath "$target")
base=${abs##*/}

if [ -d /workspaces/stash ]; then
    stash=/workspaces/stash
elif [ -d "$HOME/stash" ]; then
    stash=$HOME/stash
else
    echo "share: no stash directory at /workspaces/stash or ~/stash" >&2
    exit 1
fi

parent=${abs%/*}
toplevel=$(git -C "$parent" rev-parse --show-toplevel 2>/dev/null || pwd)
project=${toplevel##*/}

dst=$stash/share/$project
mkdir -p "$dst"
cp -R "$abs" "$dst/"

if [ -z "${SHARE_BASE_URL:-}" ]; then
    echo "→ $dst/$base"
    echo "share: set SHARE_BASE_URL on the host for a tailnet URL" >&2
    exit 0
fi

url="$SHARE_BASE_URL/$project/$base"
printf '\033]52;c;%s\033\\' "$(printf '%s' "$url" | base64 -w0)"
echo "→ $url (clipboard)"
