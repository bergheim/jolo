#!/bin/sh
set -e

# wt — lightweight in-container worktree manager
# Creates git worktrees under $WORKSPACE/.worktrees/<name> as windows
# (wt:<name>) in the current tmux session. Switch with `wt <name>` or tmux's
# `C-b w` / `C-b <n>`.

ADJECTIVES="brave swift calm bold keen wild warm cool fair wise"
NOUNS="panda falcon river mountain oak wolf hawk cedar fox bear"

WS="${WORKSPACE_FOLDER:-$(pwd)}"
# Worktrees live under the main workspace, which is bind-mounted from the host
# and survives container rebuilds. A bare /workspaces/<name> sits on the
# container's ephemeral overlay and gets nuked on recreate (the branch refs in
# $WS/.git persist, but the working dir vanishes).
WT_BASE="$WS/.worktrees"

usage() {
    cat <<EOF
Usage: wt <command> [options]

Commands:
  new <name> [--from <ref>] [-p <prompt>]   Create worktree + tmux window
  <name>                                     Switch to worktree window
  list, ls                                   List worktree windows
  sync [<name>]                              Rebase <name> on main's branch (defaults to current worktree if cwd is one; fzf picks otherwise)
  land [<name>] [--rm]                       Rebase <name> on current branch and merge into it (run from main; fzf picks if no name; --rm also removes worktree+branch+window afterwards)
  delete [<name>], rm [<name>]               Remove worktree + branch + tmux window (fzf picks if no name)
  prune                                      Clean up stale worktree refs
  (no args)                                  List worktree windows
EOF
}

random_name() {
    adj=$(echo "$ADJECTIVES" | tr ' ' '\n' | shuf -n1)
    noun=$(echo "$NOUNS" | tr ' ' '\n' | shuf -n1)
    echo "${adj}-${noun}"
}

require_tmux() {
    [ -n "$TMUX" ] && return
    echo "error: must be inside tmux" >&2
    exit 1
}

window_name() {
    echo "wt:$1"
}

branch_exists() {
    git -C "$WS" show-ref --verify --quiet "refs/heads/$1"
}

# Keep .worktrees/ out of the main repo's view: it lives inside the working
# tree now, so without this it shows as untracked and gets walked by rg/agents.
# Written to info/exclude (per-repo, persistent, no commit). Idempotent.
ensure_worktree_excluded() {
    git_common=$(git -C "$WS" rev-parse --git-common-dir 2>/dev/null) || return 0
    case "$git_common" in /*) ;; *) git_common="$WS/$git_common" ;; esac
    exclude="$git_common/info/exclude"
    mkdir -p "$git_common/info"
    grep -qxF '.worktrees/' "$exclude" 2>/dev/null && return 0
    printf '.worktrees/\n' >>"$exclude"
}

# In a list-windows snapshot (`#{window_id} #{window_name}` per line, $2 above),
# echo the id of the row whose name equals $1, or nothing. tmux window names
# aren't unique and `-t "=name"` picks the lowest index, so resolve to id and
# target that. Pulled out so cmd_list can fetch the snapshot once and reuse it
# across all worktrees instead of forking tmux per row.
match_window_id() {
    printf '%s\n' "$2" | awk -v w="$1" '$2 == w { print $1; exit }'
}

# Single-shot lookup of the wt:<name> window in the current session. Falls
# through to empty for non-tmux callers (list-windows with no -t is scoped to
# the current session; never -a).
wt_window_id() {
    match_window_id "$(window_name "$1")" \
        "$(tmux list-windows -F '#{window_id} #{window_name}' 2>/dev/null)"
}

# Best-effort window close. No-op when $1 is empty (caller is outside tmux, or
# no wt window matched). Stderr swallowed because tmux complains loudly when
# the id has already gone away (e.g. user closed it manually).
kill_window() {
    [ -n "$1" ] && tmux kill-window -t "$1" 2>/dev/null || true
}

# Print "name<TAB>branch" for each worktree under $WT_BASE. Used to feed fzf or
# to count candidates. The main WS is excluded automatically — it sits above
# $WT_BASE, not under it.
list_worktree_candidates() {
    git -C "$WS" worktree list --porcelain | awk -v base="$WT_BASE/" '
        /^worktree / { path=$2; next }
        /^branch refs\/heads\// {
            sub(/^refs\/heads\//, "", $2); branch=$2; next
        }
        /^$/ {
            if (path && branch && index(path, base) == 1) {
                n = split(path, parts, "/")
                printf "%s\t%s\n", parts[n], branch
            }
            path=""; branch=""
        }
    '
}

# Interactive fzf picker. Echoes selected worktree name on stdout and
# returns 0; returns 1 if fzf is missing, no TTY, no candidates, or the
# user aborted. Caller decides what to do on failure.
pick_worktree() {
    prompt="$1"
    # /dev/tty rather than [ -t 0 ]/[ -t 1 ]: this function is called inside
    # `name=$(pick_worktree ...)`, where stdout is always captured (so [ -t 1 ]
    # is always false). fzf opens /dev/tty itself for its UI, so /dev/tty's
    # accessibility is what actually tells us we're in an interactive context.
    [ -r /dev/tty ] && [ -w /dev/tty ] || return 1
    command -v fzf >/dev/null 2>&1 || return 1

    candidates=$(list_worktree_candidates)
    [ -z "$candidates" ] && return 1

    # Target branch is whatever's checked out in the main workspace — that's
    # what `wt land` would rebase against, so it's the most useful diff base
    # for the preview. Fall back to main → master if WS is detached.
    target=$(git -C "$WS" branch --show-current 2>/dev/null)
    [ -z "$target" ] && target="main"

    # Preview: single git plumbing call wrapped with shell glue. {1}=name,
    # {2}=branch (fzf shell-quotes both, so they slot in safely as words).
    # stderr → stdout so any git errors are visible inside the preview pane
    # instead of vanishing.
    preview='p='"$WT_BASE"'/{1}; t='"$target"'; br={2};'
    preview="$preview"' ahead=$(git -C "$p" rev-list --count "$t..$br" 2>&1);'
    preview="$preview"' echo "branch: $br";'
    preview="$preview"' echo "target: $t  (ahead by $ahead commit(s))";'
    preview="$preview"' echo;'
    preview="$preview"' echo "── HEAD ──";'
    preview="$preview"' git -C "$p" log -1 --format="%h %s%n%n%b" "$br" 2>&1;'
    preview="$preview"' case "$ahead" in (0|"") : ;; (*[!0-9]*) : ;; (*) echo; echo "── commits ahead of $t ──"; git -C "$p" log --oneline --decorate "$t..$br" 2>&1 ;; esac'

    selected=$(printf '%s\n' "$candidates" \
        | fzf --prompt="$prompt > " --height=60% --reverse \
              --with-nth=1,2 --delimiter='\t' \
              --preview="$preview" \
              --preview-window=right:55%:wrap)
    [ -z "$selected" ] && return 1
    printf '%s\n' "$selected" | awk -F'\t' '{print $1}'
}

# If cwd is $WT_BASE/<name>(/...), echo <name>. Otherwise echo nothing. Used to
# default `wt sync`/`wt rm` to the worktree you're standing in, and to refuse
# `wt land` from inside the worktree being landed.
current_worktree_name() {
    case "$PWD/" in
        "$WT_BASE"/*)
            rest="${PWD#"$WT_BASE"/}"
            cwd_name="${rest%%/*}"
            if [ -n "$cwd_name" ] && [ -d "$WT_BASE/$cwd_name" ]; then
                printf '%s\n' "$cwd_name"
            fi
            ;;
    esac
}

assert_worktree_clean() {
    if [ -n "$(git -C "$1" status --porcelain 2>/dev/null)" ]; then
        echo "error: $2 has uncommitted changes" >&2
        exit 1
    fi
}

# Echo the branch checked out in the main workspace, or print an error and
# return 1. Caller wraps in `target=$(resolve_target_branch ...) || exit 1`
# because `exit` from inside $() only kills the subshell.
resolve_target_branch() {
    candidate="$1"
    verb="$2"
    target=$(git -C "$WS" branch --show-current)
    if [ -z "$target" ]; then
        echo "error: main workspace is in detached HEAD" >&2
        return 1
    fi
    if [ "$target" = "$candidate" ]; then
        echo "error: main is on branch '$candidate' — nothing to $verb" >&2
        return 1
    fi
    printf '%s\n' "$target"
}

# Open a window for the worktree in the current session. new-window auto-selects
# it (no -d), so callers land in the new window without a separate switch.
create_window() {
    name="$1"
    prompt="$2"
    wt_path="$WT_BASE/$name"
    win=$(window_name "$name")

    if [ -n "$prompt" ]; then
        tmux new-window -n "$win" -c "$wt_path" "claude $prompt"
    else
        tmux new-window -n "$win" -c "$wt_path"
    fi
}

cmd_new() {
    # Parse arguments
    name=""
    from_ref=""
    prompt=""
    while [ $# -gt 0 ]; do
        case "$1" in
            --from)
                shift
                from_ref="$1"
                ;;
            -p)
                shift
                prompt="$1"
                ;;
            *)
                [ -z "$name" ] && name="$1"
                ;;
        esac
        shift
    done

    [ -z "$name" ] && name=$(random_name)

    if [ ! -d "$WS/.git" ] && [ ! -f "$WS/.git" ]; then
        echo "error: not in a git repository" >&2
        exit 1
    fi

    require_tmux

    wt_path="$WT_BASE/$name"

    if [ -d "$wt_path" ]; then
        echo "error: worktree already exists at $wt_path" >&2
        exit 1
    fi

    ensure_worktree_excluded
    mkdir -p "$WT_BASE"

    # Create the worktree
    if [ -n "$from_ref" ]; then
        git -C "$WS" worktree add -b "$name" "$wt_path" "$from_ref"
    else
        git -C "$WS" worktree add -b "$name" "$wt_path"
    fi

    create_window "$name" "$prompt"
    echo "created worktree $name at $wt_path"
}

cmd_switch() {
    name="$1"
    wt_path="$WT_BASE/$name"

    require_tmux

    wid=$(wt_window_id "$name")
    if [ -n "$wid" ]; then
        tmux select-window -t "$wid"
    elif [ -d "$wt_path" ]; then
        create_window "$name" ""
    elif branch_exists "$name"; then
        # Dir gone (e.g. a pre-persistence worktree nuked on container rebuild)
        # but the branch survived in $WS/.git. Re-materialize it from the branch,
        # then open it. prune first to clear the dead registration so add works.
        echo "worktree '$name' missing — re-materializing from branch '$name'" >&2
        ensure_worktree_excluded
        mkdir -p "$WT_BASE"
        git -C "$WS" worktree prune
        git -C "$WS" worktree add "$wt_path" "$name"
        create_window "$name" ""
    else
        echo "error: no worktree '$name' found" >&2
        exit 1
    fi
}

cmd_list() {
    current=""
    # One snapshot of all current-session windows, looked up per worktree row
    # via match_window_id — avoids forking tmux once per worktree.
    open_windows=""
    if [ -n "$TMUX" ]; then
        current=$(tmux display-message -p '#{window_id}')
        open_windows=$(tmux list-windows -F '#{window_id} #{window_name}' 2>/dev/null)
    fi

    # One git call gets last-commit info for every branch — cheap regardless
    # of worktree count. Format: "<branch>\t<sha>\t<reltime>\t<subject>"
    branch_info=$(git -C "$WS" for-each-ref \
        --format='%(refname:short)%09%(objectname:short)%09%(committerdate:relative)%09%(contents:subject)' \
        refs/heads/ 2>/dev/null)

    # Build rows tab-separated, then pipe through `column -t` so each column
    # auto-sizes to the widest entry instead of being padded to a fixed
    # one-size-fits-all width. Tab as the separator survives subjects with
    # spaces; column treats consecutive tabs as one delimiter.
    git -C "$WS" worktree list --porcelain | while IFS= read -r line; do
        case "$line" in
            # Only worktrees under $WT_BASE; the main WS sits above it and is
            # excluded automatically. A registered-but-missing dir (its working
            # tree got nuked on container rebuild) still lists here — that's the
            # point: the user sees it and can `wt switch` to re-materialize it.
            "worktree $WT_BASE/"*)
                wt_path="${line#worktree }"
                wt_name="${wt_path##*/}"
                ;;
            "branch refs/heads/"*)
                branch="${line#branch refs/heads/}"
                ;;
            "")
                [ -z "$wt_name" ] && continue
                wid=$(match_window_id "$(window_name "$wt_name")" "$open_windows")
                if [ -n "$wid" ]; then
                    active="[window open]"
                else
                    active="[no window]"
                fi
                marker="  "
                [ -n "$wid" ] && [ "$current" = "$wid" ] && marker="* "

                # Collapse name+branch into one column when they match (the
                # common case — `wt new <name>` always sets branch == name).
                if [ "$wt_name" = "$branch" ]; then
                    display="$wt_name"
                else
                    display="$wt_name (→ $branch)"
                fi

                # Look up last-commit info for this branch from the cached
                # for-each-ref output. Use cut so subjects containing tabs
                # don't get truncated mid-line.
                match=$(printf '%s\n' "$branch_info" | awk -F'\t' -v b="$branch" '$1 == b { print; exit }')
                if [ -n "$match" ]; then
                    sha=$(printf '%s' "$match" | cut -f2)
                    reltime=$(printf '%s' "$match" | cut -f3)
                    subject=$(printf '%s' "$match" | cut -f4-)
                    if [ ${#subject} -gt 60 ]; then
                        subject=$(printf '%.57s...' "$subject")
                    fi
                else
                    sha="-"
                    reltime=""
                    subject=""
                fi

                printf '%s%s\t%s\t%s\t%s\t%s\n' \
                    "$marker" "$display" "$active" "$sha" "$reltime" "$subject"
                wt_name=""
                branch=""
                ;;
        esac
    done | column -t -s "$(printf '\t')"
}

cmd_land() {
    name=""
    rm_after=0
    while [ $# -gt 0 ]; do
        case "$1" in
            --rm) rm_after=1 ;;
            -*)   echo "error: unknown flag '$1'" >&2; exit 1 ;;
            *)    [ -z "$name" ] && name="$1" ;;
        esac
        shift
    done

    if [ -z "$name" ]; then
        name=$(pick_worktree "land") || { echo "error: name required (and no worktree picked)" >&2; exit 1; }
    fi

    wt_path="$WT_BASE/$name"
    [ ! -d "$wt_path" ] && { echo "error: no worktree '$name' found" >&2; exit 1; }

    if [ "$(current_worktree_name)" = "$name" ]; then
        echo "error: run 'wt land' from main, not from inside the worktree being landed" >&2
        exit 1
    fi

    assert_worktree_clean "$wt_path" "worktree '$name'"
    assert_worktree_clean "$WS" "main workspace"

    target=$(resolve_target_branch "$name" "land") || exit 1

    echo "rebasing $name on $target..."
    if ! git -C "$wt_path" rebase "$target"; then
        echo "" >&2
        echo "rebase failed; resolve conflicts in $wt_path then re-run 'wt land $name'" >&2
        echo "or run 'git -C $wt_path rebase --abort' to back out" >&2
        exit 1
    fi

    ahead=$(git -C "$WS" rev-list --count "$target..$name")
    if [ "$ahead" -eq 0 ]; then
        echo "no commits to merge — $target is already up to date with $name"
    elif [ "$ahead" -eq 1 ]; then
        echo "merging $name into $target (fast-forward, 1 commit)..."
        git -C "$WS" merge --ff-only "$name"
    else
        echo "merging $name into $target (--no-ff, $ahead commits)..."
        git -C "$WS" merge --no-ff "$name"
    fi

    if git -C "$WS" remote get-url origin >/dev/null 2>&1; then
        echo "pushing $target to origin..."
        git -C "$WS" push origin "$target"
    fi

    if [ "$rm_after" = "1" ]; then
        echo "landed $name into $target — cleaning up (--rm)..."
        cmd_delete "$name"
    else
        echo "landed $name into $target — run 'wt rm $name' to clean up"
    fi
}

cmd_sync() {
    name=""
    while [ $# -gt 0 ]; do
        case "$1" in
            -*)   echo "error: unknown flag '$1'" >&2; exit 1 ;;
            *)    [ -z "$name" ] && name="$1" ;;
        esac
        shift
    done

    # No name: prefer the worktree we're standing in, then fzf-pick.
    [ -z "$name" ] && name=$(current_worktree_name)
    if [ -z "$name" ]; then
        name=$(pick_worktree "sync") || { echo "error: name required (and no worktree picked)" >&2; exit 1; }
    fi

    wt_path="$WT_BASE/$name"
    [ ! -d "$wt_path" ] && { echo "error: no worktree '$name' found" >&2; exit 1; }

    assert_worktree_clean "$wt_path" "worktree '$name'"

    target=$(resolve_target_branch "$name" "sync") || exit 1

    echo "rebasing $name on $target..."
    if ! git -C "$wt_path" rebase "$target"; then
        echo "" >&2
        echo "rebase failed; resolve conflicts in $wt_path (magit, git mergetool, etc.)" >&2
        echo "or run 'git -C $wt_path rebase --abort' to back out" >&2
        exit 1
    fi
    echo "synced $name with $target"
}

cmd_delete() {
    name="$1"
    if [ -z "$name" ]; then
        name=$(pick_worktree "rm") || { echo "error: name required (and no worktree picked)" >&2; exit 1; }
    fi
    wt_path="$WT_BASE/$name"
    wid=$(wt_window_id "$name")

    # Stale path: just prune refs and tear down the window.
    if [ ! -d "$wt_path" ]; then
        kill_window "$wid"
        git -C "$WS" worktree prune
        git -C "$WS" branch -D "$name" 2>/dev/null || true
        echo "pruned stale worktree $name"
        return
    fi

    if [ -n "$(git -C "$wt_path" status --porcelain 2>/dev/null)" ]; then
        printf "worktree '%s' has uncommitted changes. delete anyway? [y/N] " "$name"
        read -r answer
        case "$answer" in
            [yY]*) ;;
            *) echo "aborted"; exit 1 ;;
        esac
    fi

    git -C "$WS" worktree remove --force "$wt_path"
    # Branches are shared across all worktrees of a repo.
    git -C "$WS" branch -D "$name" 2>/dev/null || true

    # Echo before closing the window: if you ran this from inside the worktree's
    # own window, kill-window closes the pane this script runs in, so the
    # message must land first. tmux moves the client to an adjacent window.
    # ${wid:+...} omits the window phrase when there's nothing to close (e.g.
    # called from outside tmux via cmd_land --rm).
    echo "removed worktree $name (branch deleted${wid:+, tmux window closed})"
    kill_window "$wid"
}

cmd_prune() {
    git -C "$WS" worktree prune -v
}

# Main dispatch
case "${1:-}" in
    new)
        shift
        cmd_new "$@"
        ;;
    list|ls|"")
        cmd_list
        ;;
    land)
        shift
        cmd_land "$@"
        ;;
    sync)
        shift
        cmd_sync "$@"
        ;;
    delete|rm)
        shift
        cmd_delete "${1:-}"
        ;;
    prune)
        cmd_prune
        ;;
    -h|--help|help)
        usage
        ;;
    *)
        # Treat as switch if it looks like a name
        cmd_switch "$1"
        ;;
esac
