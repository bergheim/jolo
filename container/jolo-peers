#!/usr/bin/env python3
"""Read-only view of peer jolo devcontainers from inside a container.

Reads ~stash~/.jolo/peers.json (populated by the host-side jolo CLI when
containers start/stop) and prints the other running containers so an
agent can see what else is live.

No container-runtime checks are performed from inside a container —
stale entries are the host's responsibility to prune.
"""

from __future__ import annotations

import argparse
import json
import os
import sys
from pathlib import Path

_STASH_CANDIDATES = (
    Path("/workspaces/stash"),
    Path(os.environ.get("HOME", "")) / "stash",
)


def registry_path() -> Path:
    for base in _STASH_CANDIDATES:
        if base.is_dir():
            return base / ".jolo" / "peers.json"
    return _STASH_CANDIDATES[0] / ".jolo" / "peers.json"


def load_peers() -> list[dict]:
    path = registry_path()
    if not path.exists():
        return []
    try:
        data = json.loads(path.read_text())
    except (OSError, ValueError):
        return []
    if not isinstance(data, list):
        return []
    return [e for e in data if isinstance(e, dict) and "container" in e]


def format_entries(peers: list[dict]) -> str:
    if not peers:
        return "No peer containers registered."
    peers = sorted(peers, key=lambda p: p.get("project", ""))
    lines = []
    for p in peers:
        name = p.get("container", "?")
        project = p.get("project", "?")
        port = p.get("port", "-")
        branch = p.get("branch", "-")
        url = p.get("url", "")
        line = (
            f"  {name:<24} {project:<20} port {str(port):<5} branch {branch}"
        )
        if url:
            line += f"  {url}"
        lines.append(line)
    return "\n".join(lines)


def main(argv: list[str] | None = None) -> int:
    parser = argparse.ArgumentParser(
        description="Show other running jolo devcontainers."
    )
    parser.add_argument(
        "--json",
        dest="as_json",
        action="store_true",
        help="Output as JSON",
    )
    args = parser.parse_args(argv)
    peers = load_peers()
    if args.as_json:
        print(json.dumps(peers, indent=2, sort_keys=True))
    else:
        print(format_entries(peers))
    return 0


if __name__ == "__main__":
    sys.exit(main())
