set shell := ["bash", "-eo", "pipefail", "-c"]

# Run the project
run:
    mix phx.server

# Run with auto-reload (logs to dev.log for agent visibility)
dev: db _ensure-db
    mix phx.server 2>&1 | tee dev.log

# Create database if it doesn't exist and run migrations
_ensure-db:
    mix ecto.create 2>/dev/null; mix ecto.migrate

# Run tests
test: db
    mix test

# Run tests continuously (on file change)
test-watch:
    fd -e ex -e exs -e heex | entr -cn mix test

# Add a dependency (add to mix.exs manually, then run this)
add:
    mix deps.get

# Setup database
setup:
    mix ecto.setup

# Run migrations
migrate:
    mix ecto.migrate

# Reset database
reset:
    mix ecto.reset

# Audit a route with Lighthouse (mobile|desktop) — HTML + JSON under scratch/lighthouse/, then `share`s the HTML
lighthouse ROUTE='/' FORM_FACTOR='mobile':
    #!/usr/bin/env bash
    set -euo pipefail
    slug=$(printf '%s' "{{ROUTE}}" | sed 's|^/||; s|/|-|g; s|[^A-Za-z0-9_.-]|_|g')
    : "${slug:=root}"
    mkdir -p scratch/lighthouse
    outdir=$(mktemp -d "scratch/lighthouse/${slug}-{{FORM_FACTOR}}-$(date +%Y%m%dT%H%M%S)-XXXXXX")
    scripts/lighthouse-run "{{ROUTE}}" "{{FORM_FACTOR}}" "$outdir"
    json="$outdir/report.report.json"
    score=$(jq -r '.categories.performance.score' "$json")
    echo "route:      {{ROUTE}}  ({{FORM_FACTOR}})"
    echo "score:      $score"
    for a in first-contentful-paint largest-contentful-paint total-blocking-time cumulative-layout-shift speed-index; do
        printf "%-26s %s\n" "$a:" "$(jq -r ".audits[\"$a\"].displayValue" "$json")"
    done
    echo "report:     $outdir/report.report.html"
    share "$outdir/report.report.html"
