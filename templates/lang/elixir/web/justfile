set shell := ["bash", "-eo", "pipefail", "-c"]

# Run the project
run:
    mix phx.server

# Run with auto-reload (logs to dev.log for agent visibility)
dev: db _ensure-db
    mix phx.server 2>&1 | tee dev.log

# Create database if it doesn't exist and run migrations
_ensure-db:
    mix ecto.create 2>/dev/null; mix ecto.migrate

# Run tests
test: db
    mix test

# Run tests continuously (on file change)
test-watch:
    fd -e ex -e exs -e heex | entr -cn mix test

# Add a dependency (add to mix.exs manually, then run this)
add:
    mix deps.get

# Setup database
setup:
    mix ecto.setup

# Run migrations
migrate:
    mix ecto.migrate

# Reset database
reset:
    mix ecto.reset
