set shell := ["bash", "-eo", "pipefail", "-c"]

# Run the project
run:
    go run .

# Run with auto-reload (logs to dev.log for agent visibility)
dev:
    air 2>&1 | tee dev.log

# Run tests
test:
    go test ./...

# Run tests continuously (on file change)
test-watch:
    fd -e go | entr -cn go test ./...

# Add a dependency
add *packages:
    go get {{packages}}
