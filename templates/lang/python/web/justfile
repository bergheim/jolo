set shell := ["bash", "-eo", "pipefail", "-c"]

# Run the project
run:
    uv run {{PROJECT_NAME}}

# Run with auto-reload (logs to dev.log for agent visibility)
dev:
    uv run uvicorn {{MODULE_NAME}}.app:app --host 0.0.0.0 --port $PORT --reload --app-dir src 2>&1 | tee dev.log

# Run tests
test:
    uv run pytest

# Run tests continuously (on file change)
test-watch:
    fd -e py -e html | entr -cn uv run pytest

# Add a dependency
add *packages:
    uv add {{packages}}

# Profile a route (curl ?profile=1) and save the flamegraph to scratch/
profile path="/":
    #!/usr/bin/env bash
    set -euo pipefail
    mkdir -p scratch
    slug=$(printf '%s' "{{path}}" | sed 's|^/||;s|/|-|g')
    [ -z "$slug" ] && slug=root
    out="scratch/profile-$slug-$(date +%Y%m%dT%H%M%S).html"
    curl -fsS "http://127.0.0.1:$PORT{{path}}?profile=1" -o "$out"
    echo "wrote $out"
