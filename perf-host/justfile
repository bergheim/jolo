set shell := ["zsh", "-cu"]

# default — show available recipes
default:
    @just --list --unsorted

# bring up the full stack
up:
    podman compose up -d --build

# stop everything (data survives)
down:
    podman compose down

# scorched-earth rebuild (when --no-cache lies — see stash gotcha note 20260421T192408)
nuke:
    podman compose down
    -podman image rm perf-host-trigger:latest localhost/perf-host-trigger:latest
    podman builder prune -af
    podman compose up -d --build

# tail logs for a service: `just logs trigger`
logs service="trigger":
    podman compose logs -f {{service}}

# fire the bundled demo rig
demo:
    @curl -sS -X POST http://berghome.ts.glvortex.net:8888/api/run/demo | jq

# list recent ledger entries
runs:
    @curl -sS http://berghome.ts.glvortex.net:8888/api/runs | jq '.runs | map({run_id, project, sha, validity_status, failure_reason})'

# list projects with run counts
projects:
    @curl -sS http://berghome.ts.glvortex.net:8888/api/projects | jq

# quick health probe
health:
    @curl -sS http://berghome.ts.glvortex.net:8888/api/health | jq

# run unit tests
test:
    uv run pytest tests/ -v

# lint
lint:
    uv run ruff check trigger/ tests/

# render the bundled demo rig as the k6 script that would run (no execution)
render:
    @curl -sS -X POST http://berghome.ts.glvortex.net:8888/api/debug/render \
      -H 'content-type: application/json' \
      -d '{"rig_path":"/app/rigs/demo.toml","sha":"deadbeef0000","testbed":"hub-bare","run_id":"DEBUG"}' \
      | jq -r .k6_script

# open the cross-project overview dashboard in default browser
overview:
    @echo "http://berghome.ts.glvortex.net:8888/grafana/d/perf-host-overview"

# open the k6 dashboard for the most recent run
last-run-dashboard:
    @LATEST=$(curl -sS http://berghome.ts.glvortex.net:8888/api/runs | jq -r '.runs[0].run_id') && \
      echo "http://berghome.ts.glvortex.net:8888/grafana/d/k6-prom/k6-prometheus?var-testid=$LATEST&from=now-15m&to=now"
