{
	auto_https off
	admin off
}

:80 {
	@grafana path /grafana /grafana/*
	handle @grafana {
		reverse_proxy grafana:3000
	}

	handle_path /vm/* {
		reverse_proxy victoriametrics:8428
	}

	handle_path /api/* {
		reverse_proxy trigger:8000
	}

	handle /viewer/* {
		root * /srv
		file_server
	}

	handle /profiles/* {
		root * /srv
		file_server browse
	}

	respond / "perf-host: try /grafana, /vm, /api/health, /viewer/, /profiles/"
}
