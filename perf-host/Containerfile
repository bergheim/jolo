ARG PYTHON_VERSION=3.13
ARG K6_VERSION=0.55.0
ARG TARGETARCH=amd64

FROM python:${PYTHON_VERSION}-alpine AS k6
ARG K6_VERSION
ARG TARGETARCH
RUN apk add --no-cache curl tar \
 && case "${TARGETARCH}" in \
      amd64) K6_ARCH=linux-amd64 ;; \
      arm64) K6_ARCH=linux-arm64 ;; \
      *) echo "unsupported TARGETARCH=${TARGETARCH}" >&2; exit 1 ;; \
    esac \
 && curl -fsSL "https://github.com/grafana/k6/releases/download/v${K6_VERSION}/k6-v${K6_VERSION}-${K6_ARCH}.tar.gz" \
    | tar -xz -C /tmp \
 && mv "/tmp/k6-v${K6_VERSION}-${K6_ARCH}/k6" /usr/local/bin/k6 \
 && chmod +x /usr/local/bin/k6

FROM python:${PYTHON_VERSION}-alpine
RUN apk add --no-cache curl tini
COPY --from=k6 /usr/local/bin/k6 /usr/local/bin/k6
WORKDIR /app
COPY trigger/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY trigger/ .
ENV PROFILE_DIR=/srv/profiles \
    VM_URL=http://victoriametrics:8428
EXPOSE 8000
ENTRYPOINT ["/sbin/tini", "--"]
CMD ["uvicorn", "main:app", "--host", "0.0.0.0", "--port", "8000"]
